{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "josyn-schedule.schema.json",
  "title": "JOSYN Schedule Definition",
  "description": "This schema is normative for structure. Semantics are defined in ADR-026 (josyn-platform/decisions/ADR-026-schedule-definition-language.md).",
  "type": "array",
  "items": { "$ref": "#/$defs/rule" },

  "$defs": {

    "dayAbbrev": {
      "type": "string",
      "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
    },

    "monthAbbrev": {
      "type": "string",
      "enum": ["jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec"]
    },

    "timeString": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
    },

    "isoDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "annualDate": {
      "type": "string",
      "pattern": "^\\d{2}-\\d{2}$"
    },

    "dateBound": {
      "oneOf": [
        { "$ref": "#/$defs/isoDate" },
        { "$ref": "#/$defs/annualDate" }
      ]
    },

    "durationString": {
      "type": "string",
      "pattern": "^[1-9][0-9]*[mh]$"
    },

    "daysField": {
      "oneOf": [
        { "type": "string", "enum": ["weekdays", "weekend", "daily"] },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/dayAbbrev" },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },

    "nthField": {
      "oneOf": [
        { "type": "integer", "minimum": 1, "maximum": 5 },
        { "type": "string",  "pattern": "^(last|last-[1-9][0-9]*)$" }
      ]
    },

    "dayField": {
      "oneOf": [
        { "type": "integer", "minimum": 1, "maximum": 31 },
        { "type": "string",  "enum": ["last", "last_business"] }
      ]
    },

    "dateOrRange": {
      "oneOf": [
        { "$ref": "#/$defs/isoDate" },
        {
          "type": "object",
          "required": ["from", "to"],
          "properties": {
            "from": { "$ref": "#/$defs/isoDate" },
            "to":   { "$ref": "#/$defs/isoDate" }
          },
          "additionalProperties": false
        }
      ]
    },

    "rule": {
      "oneOf": [
        { "$ref": "#/$defs/intervalRule" },
        { "$ref": "#/$defs/fixedRule" },
        { "$ref": "#/$defs/nthWeekdayRule" },
        { "$ref": "#/$defs/monthlyDateRule" },
        { "$ref": "#/$defs/weekIntervalRule" },
        { "$ref": "#/$defs/onceRule" },
        { "$ref": "#/$defs/excludeRule" }
      ]
    },

    "intervalRule": {
      "type": "object",
      "required": ["type", "days", "start", "end", "every"],
      "properties": {
        "type":        { "const": "interval" },
        "days":        { "$ref": "#/$defs/daysField" },
        "start":       { "$ref": "#/$defs/timeString" },
        "end":         { "$ref": "#/$defs/timeString" },
        "every":       { "$ref": "#/$defs/durationString" },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "fixedRule": {
      "type": "object",
      "required": ["type", "days", "times"],
      "properties": {
        "type":        { "const": "fixed" },
        "days":        { "$ref": "#/$defs/daysField" },
        "times":       { "type": "array", "items": { "$ref": "#/$defs/timeString" }, "minItems": 1 },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "nthWeekdayRule": {
      "type": "object",
      "required": ["type", "weekday", "nth", "period", "times"],
      "properties": {
        "type":        { "const": "nth_weekday" },
        "weekday":     { "$ref": "#/$defs/dayAbbrev" },
        "nth":         { "$ref": "#/$defs/nthField" },
        "period":      { "type": "string", "enum": ["month", "quarter", "year"] },
        "times":       { "type": "array", "items": { "$ref": "#/$defs/timeString" }, "minItems": 1 },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "monthlyDateRule": {
      "type": "object",
      "required": ["type", "day", "times"],
      "properties": {
        "type":        { "const": "monthly_date" },
        "day":         { "$ref": "#/$defs/dayField" },
        "times":       { "type": "array", "items": { "$ref": "#/$defs/timeString" }, "minItems": 1 },
        "months":      { "type": "array", "items": { "$ref": "#/$defs/monthAbbrev" }, "minItems": 1, "uniqueItems": true },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "weekIntervalRule": {
      "type": "object",
      "required": ["type", "days", "times", "everyWeeks", "anchor"],
      "properties": {
        "type":        { "const": "week_interval" },
        "days":        { "$ref": "#/$defs/daysField" },
        "times":       { "type": "array", "items": { "$ref": "#/$defs/timeString" }, "minItems": 1 },
        "everyWeeks":  { "type": "integer", "minimum": 1 },
        "anchor":      { "$ref": "#/$defs/isoDate" },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "onceRule": {
      "type": "object",
      "required": ["type", "datetime"],
      "properties": {
        "type":        { "const": "once" },
        "datetime":    { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2} ([01][0-9]|2[0-3]):[0-5][0-9]$" },
        "activeFrom":  { "$ref": "#/$defs/dateBound" },
        "activeUntil": { "$ref": "#/$defs/dateBound" }
      },
      "additionalProperties": false
    },

    "excludeRule": {
      "type": "object",
      "required": ["type", "dates"],
      "properties": {
        "type":  { "const": "exclude" },
        "dates": { "type": "array", "items": { "$ref": "#/$defs/dateOrRange" }, "minItems": 1 }
      },
      "additionalProperties": false
    }

  }
}
